<html>
    <head>
        <title> Personal Details </title>
    </head>
    <body>
        <h1> Personal Detail Form</h1>
        <form>
            <fieldset>
                <legend> personal detail form</legend>
                <input type="text" id="name"><br><br>
                <label> Email ID</label>
                <input type="text" id="email"><br><br>
                <label> Password</label>
                <input type="password" id="password"><br><br>
                <label> Gender</label><br>
                <input type="radio" id="female" name="gender" value="female">Female<br>
                <input type="radio" id="male" name="gender" value="male">Male<br><br>
                <label> Favourite city</label><br>
                <input type="checkbox" id="city" value="banglore">Banglore<br>
                <input type="checkbox" id="city" value="Bhavnagar">Bhavnagar<br>
                <input type="checkbox" id="city" value="delhi">delhi<br>
                <input type="checkbox" id="city" value="chennai">chennai<br>
              </fieldset>
            <label> Favourite Food</label>
            
        </form>
    </body>